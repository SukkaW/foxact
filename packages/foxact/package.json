{
  "name": "foxact",
  "version": "0.3.4",
  "private": true,
  "description": "React Hooks/Utils done right. For browser, SSR, and React Server Components.",
  "homepage": "https://foxact.skk.moe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SukkaW/foxact.git"
  },
  "bugs": {
    "url": "https://github.com/SukkaW/foxact/issues"
  },
  "files": [
    "**"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin swc3 --bundleConfigAsCjs",
    "postbuild": "SWC_NODE_IGNORE_DYNAMIC=1 node -r @swc-node/register tools/postbuild.ts",
    "test": "SWC_NODE_IGNORE_DYNAMIC=1 SWC_NODE_INLINE_SOURCE_MAP=1 nyc --reporter text --reporter text-summary --reporter lcov mocha --require @swc-node/register --require test/setup.ts --full-trace 'src/**/*.test.{ts,tsx}'",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "React",
    "Hooks"
  ],
  "author": "Sukka <https://skk.moe>",
  "license": "MIT",
  "dependencies": {
    "client-only": "^0.0.1",
    "event-target-bus": "^1.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@napi-rs/magic-string": "^0.3.4",
    "@package-json/types": "^0.0.13",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "brotli-size": "^4.0.0",
    "browserslist": "^4.28.2",
    "earl": "^2.0.0",
    "fdir": "^6.5.0",
    "foxts": "^5.4.2",
    "gzip-size": "6.0.0",
    "happy-dom": "^20.10.2",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "react": "*",
    "react-dom": "*",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-swc3": "^0.12.1",
    "rollup-preserve-directives": "^1.1.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
