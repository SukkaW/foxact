{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./test/**/*.ts",
    "./test/**/*.tsx",
    "./rollup.config.ts",
    "./tools/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "./dist/**/*"
  ]
}
