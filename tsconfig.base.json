{
  "compilerOptions": {
    "composite": true,
    "target": "es2018",
    "lib": ["DOM", "DOM.Iterable", "ES2022", "ESNext.WeakRef"],
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  }
}
